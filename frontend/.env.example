# =============================================================================
# DLM Frontend — .env.example
# Copy to .env (or .env.local). Restart `next dev` after changes.
# NEVER commit .env / .env.local.
# =============================================================================

# Public — exposed to the browser
# MUST use the same host:port as the running API (backend .env PORT + /api/v1).
# If you start with: uvicorn ... --port 8000  → use :8000 below.
# Prefer: backend/scripts/run_dev.ps1 (reads PORT from backend/.env)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (public client-side DSN)
NEXT_PUBLIC_SENTRY_DSN=

# PostHog (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Feature flags (public)
# Set to false for launch preview — hides checkout; browse-only mode.
NEXT_PUBLIC_FEATURE_ONLINE_BOOKING=true

# Session / idle (client) — see SESSION_MANAGEMENT.md
# Idle timer starts after last user activity or API call.
NEXT_PUBLIC_SESSION_IDLE_MINUTES=10
NEXT_PUBLIC_SESSION_WARNING_MINUTES=2

# Idle overlay animations (seasonal canvas)
NEXT_PUBLIC_ENABLE_IDLE_ANIMATIONS=true
# auto | snow | rain | summer | autumn | diwali | christmas | newyear
NEXT_PUBLIC_SEASON_MODE=auto
NEXT_PUBLIC_IDLE_ANIMATION=auto

# Admin table perf testing only (0 = off)
NEXT_PUBLIC_TABLE_PERF_MOCK_ROWS=0

# Server-only — build / sourcemap upload
SENTRY_AUTH_TOKEN=
