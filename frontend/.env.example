# =============================================================================
# DLM Frontend — .env.example
# Copy to .env (or .env.local). Restart `pnpm dev` after changes.
# NEVER commit .env / .env.local.
# =============================================================================

# --- Required (validated by lib/env.ts at build time) ------------------------
# MUST match backend PORT (backend/.env) + /api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional analytics (omit or leave commented — do NOT set empty strings) ---
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Public contact (marketing site — set real values in production) -----------
# NEXT_PUBLIC_SUPPORT_EMAIL=support@washhouse.in
# NEXT_PUBLIC_SUPPORT_PHONE=+91 80 1234 5678
# NEXT_PUBLIC_WHATSAPP_NUMBER=+91 80 1234 5678
# NEXT_PUBLIC_BUSINESS_HOURS=Mon–Sat, 9:00 AM – 7:00 PM IST
# NEXT_PUBLIC_OFFICE_ADDRESS=The WashHouse Laundry & Dryclean\nKoramangala 5th Block\nBengaluru, Karnataka 560095\nIndia

# --- Public social (marketing footer) ------------------------------------------
# NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/washhouse
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/washhouse
# NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/washhouse
# NEXT_PUBLIC_X_URL=https://x.com/washhouse
# NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@washhouse

# --- Feature flags -----------------------------------------------------------
# Must match backend FEATURE_ONLINE_BOOKING (backend/.env → GET /api/v1/config).
# When true, the UI follows online_booking_enabled from the API at runtime.
# When false, offline / call-to-book UI is always shown (API is not consulted).
# Restart uvicorn + pnpm dev after changing either flag.
NEXT_PUBLIC_FEATURE_ONLINE_BOOKING=true

# --- Session / idle ------------------------------------------------------------
NEXT_PUBLIC_SESSION_IDLE_MINUTES=10
NEXT_PUBLIC_SESSION_WARNING_MINUTES=2
NEXT_PUBLIC_ENABLE_IDLE_ANIMATIONS=true
NEXT_PUBLIC_SEASON_MODE=auto
NEXT_PUBLIC_IDLE_ANIMATION=auto

# --- Dev / perf testing --------------------------------------------------------
NEXT_PUBLIC_TABLE_PERF_MOCK_ROWS=0
NEXT_TELEMETRY_DISABLED=1

# --- Server-only (Vercel build / Sentry sourcemaps) ----------------------------
# SENTRY_AUTH_TOKEN=

# --- Vercel production (set in dashboard, not in this file) --------------------
# NEXT_PUBLIC_API_URL=https://washhouse.onrender.com/api/v1
# NEXT_PUBLIC_APP_URL=https://washhouse.vercel.app
