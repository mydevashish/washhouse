.next/
out/
next-env.d.ts

# Build / tooling caches
build/
dist/
.cache/
.parcel-cache/
.turbo/
.lighthouseci/

# Environment (never commit secrets)
.env
.env.*
!.env.example

# Vercel
.vercel/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage artifacts
coverage/
.nyc_output/
playwright-report/
test-results/
blob-report/
playwright/.cache/

# Storybook
storybook-static/

# Sentry (local CLI config)
.sentryclirc

# OS
.DS_Store
Thumbs.db

# Local image imports (processed by npm run catalog:optimize)
public/catalog/_imports/
public/marketing/_imports/
