# =============================================================================
# DLM Backend — .env.example
# Copy to .env. Never commit .env.
# =============================================================================

# App
APP_ENV=local
LOG_LEVEL=INFO
APP_NAME=dlm-backend
APP_VERSION=0.1.0

# Server — PORT must match frontend NEXT_PUBLIC_API_URL and uvicorn --port
HOST=0.0.0.0
PORT=8000

# Database (asyncpg for app; plain postgresql:// from Neon is auto-normalized)
DATABASE_URL=postgresql+asyncpg://dlm:dlm_dev_password@localhost:5432/dlm_db
# Optional: direct (non-pooler) URL for Alembic offline; derived from DATABASE_URL when unset
DATABASE_URL_DIRECT=postgresql://dlm:dlm_dev_password@localhost:5432/dlm_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Auth / JWT
JWT_ALG=HS256
JWT_SECRET=dev-secret-change-me
JWT_ISSUER=dlm
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30

# Invalidate JWTs after API restart (access + refresh both carry `sid`)
FORCE_LOGOUT_ON_RESTART=true

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000

# Migrations & seeds
AUTO_RUN_MIGRATIONS=true
AUTO_SEED_ADMIN=true
SEED_ADMIN_EMAIL=admin@yopmail.com
SEED_ADMIN_PASSWORD=Admin@1234
SEED_ADMIN_FULL_NAME=DLM Admin
AUTO_SEED_DEMO=true

# Rate limiting / cache
RATE_LIMIT_ENABLED=true
CACHE_ENABLED=true

# Observability
# SENTRY_DSN=

# Email (optional locally; required for password-reset mail in staging/production)
# Port 587 = STARTTLS (default). Port 465 = implicit SSL.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@dlm.app
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# Inbox for contact / franchise notifications (defaults to SMTP_FROM_EMAIL)
# SUPPORT_EMAIL=support@dlm.app

# SMS / WhatsApp (optional — Twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Walk-in order templates — Content SIDs (HX…) after Meta approval; omit for sandbox plain body
# TWILIO_WA_TEMPLATE_ORDER_RECEIVED=
# TWILIO_WA_TEMPLATE_ORDER_IN_PROGRESS=
# TWILIO_WA_TEMPLATE_ORDER_READY=
# TWILIO_WA_TEMPLATE_ORDER_DELIVERED=

# OTP — dev only
OTP_DEBUG=true

# Google OAuth
# GOOGLE_CLIENT_ID=

# Payments — Razorpay (India)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Feature flags
FEATURE_ONLINE_BOOKING=true
FEATURE_SUBSCRIPTIONS=false
FEATURE_SURGE_PRICING=false
